// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               Int              @id @default(autoincrement())
  fullName         String
  nationalId       String           @unique
  employeeNumber   String           @unique
  phone            String
  email            String           @unique
  passwordHash     String
  role             String           @default("customer") // "customer", "admin"
  isInstitutionAdmin Boolean        @default(false)
  institutionId    Int?             // If isInstitutionAdmin is true
  institution      Institution?     @relation("AdminInstitution", fields: [institutionId], references: [id])
  
  // Custom metadata from initial draft
  bank             String?          // Redundant with profile.salaryInstitution but kept for transition
  department       String?
  
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt @default(now())
  
  profile          FinancialProfile?
  applications     LoanApplication[]
  activeLoans      Loan[]           // RENAMED from ActiveLoan to align with doc
  reminders        Reminder[]
}

model Institution {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  type             String   // "BANK", "MICROFINANCE", "SACCO", "OTHER"
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  
  criteria         InstitutionCriteria?
  admins           User[]                @relation("AdminInstitution")
  loans            Loan[]
  profiles         FinancialProfile[]    @relation("SalaryInstitution")
  applications     LoanApplication[]     @relation("ApplicationInstitution")
}

model InstitutionCriteria {
  id                Int         @id @default(autoincrement())
  institutionId     Int         @unique
  institution       Institution @relation(fields: [institutionId], references: [id])
  
  maxDtiRatio       Float       // Maximum allowed debt-to-income ratio (%)
  minNetSalary      Float       // Minimum qualifying monthly net salary
  maxLoanMultiplier Float       // Maximum loan as multiple of monthly salary
  
  updatedAt         DateTime    @updatedAt
}

model FinancialProfile {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  user               User     @relation(fields: [userId], references: [id])
  
  employerName       String
  employmentType     String   // "CIVIL", "PRIVATE"
  monthlyNetSalary   Float
  
  salaryInstitutionId Int?
  salaryInstitution   Institution? @relation("SalaryInstitution", fields: [salaryInstitutionId], references: [id])
  
  // Legacy fields kept for compatibility or extra logic
  employmentYears    Float?
  age                Int?
  housingStatus      String?
  existingLoanAmount Float    @default(0) // Internal legacy field
  totalBorrowedAmount Float   @default(0) // Lifetime total borrowed across all banks
  bankingYears       Float    @default(0)
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Loan { // Renamed from ActiveLoan
  id                 Int             @id @default(autoincrement())
  userId             Int
  user               User            @relation(fields: [userId], references: [id])
  
  providerInstitutionId Int
  providerInstitution   Institution  @relation(fields: [providerInstitutionId], references: [id])
  
  loanAmount         Float           // Original total loan amount
  monthlyDeduction   Float           // Monthly repayment deducted from salary
  loanTermMonths     Int             // Total repayment term in months
  startDate          DateTime        // Date first deduction was made
  
  remainingBalance   Float?          // Calculated balance
  paidMonths         Int             @default(0)
  isActive           Boolean         @default(true)
  
  // Link to application if it was processed through our system
  applicationId      Int?            @unique
  application        LoanApplication? @relation(fields: [applicationId], references: [id])
  
  reminders          Reminder[]
  
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model LoanApplication {
  id                 Int        @id @default(autoincrement())
  userId             Int
  user               User       @relation(fields: [userId], references: [id])
  
  institutionId      Int
  institution        Institution @relation("ApplicationInstitution", fields: [institutionId], references: [id])
  
  amount             Float
  purpose            String
  durationMonths     Int
  monthlyInstallment Float
  riskScore          Int        @default(0)
  riskCategory       String     @default("UNKNOWN")
  dtiRatio           Float      @default(0)
  status             String     @default("PENDING") // "PENDING", "APPROVED", "REJECTED", "ACTIVE"
  
  createdAt          DateTime   @default(now())
  loan               Loan?      // If it becomes an active loan
}

model Reminder {
  id               Int      @id @default(autoincrement())
  loanId           Int
  loan             Loan     @relation(fields: [loanId], references: [id])
  userId           Int
  user             User     @relation(fields: [userId], references: [id])
  
  scheduledAt      DateTime
  sentAt           DateTime?
  channel          String   // "EMAIL", "SMS", "BOTH"
  status           String   // "PENDING", "SENT", "FAILED"
  deductionConfirmed Boolean @default(false)
  
  logs             NotificationLog[]
}

model NotificationLog {
  id               Int      @id @default(autoincrement())
  reminderId       Int
  reminder         Reminder @relation(fields: [reminderId], references: [id])
  
  deliveredAt      DateTime @default(now())
  channel          String
  success          Boolean
  errorMessage     String?
}
